# ===========================================
# API (Hono) Environment
# ===========================================

# Runtime
NODE_ENV=development
PORT=8787
LOG_LEVEL=info
# Optional local file logging directory. Leave empty to log to stdout only.
LOG_FILE_PATH=""

# In production, emit JSON logs to stdout and let infrastructure collect/rotate them.

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/db_name"

# App/API URLs
APP_URL="http://localhost:3100"
API_URL="http://localhost:8787"

# Better Auth (API side)
BETTER_AUTH_SECRET="replace-with-strong-secret"
# Optional extra allowed origins in addition to APP_URL, API_URL, and ADMIN_APP_URL.
BETTER_AUTH_ALLOWED_ORIGINS="http://localhost:3100,http://localhost:3101,http://localhost:8787"
ADMIN_APP_URL="http://localhost:3101"
ADMIN_ALLOWLIST="admin@example.com"

# Mobile JWT flow
JWT_SECRET="replace-with-strong-secret"
JWT_ISSUER="api-main"
JWT_AUDIENCE="mobile-clients"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Admin protections
# Optional extra secret for specific admin actions.
ADMIN_BAN_SECRET=""

# Social providers (OAuth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Payments
# Required to use live Dodo checkout, invoice, webhook, and discount sync flows.
DODO_PAYMENTS_API_KEY=""
DODO_PAYMENTS_WEBHOOK_SECRET=""
DODO_PAYMENTS_ENVIRONMENT="test_mode"
# Optional bearer token for scheduled GET /billing/reconcile checks.
BILLING_RECONCILIATION_SECRET=""

# Email
# Required for magic links, password reset, verification, and other outbound emails.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@example.com"
