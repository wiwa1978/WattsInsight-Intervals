# ===========================================
# Frontend (Next.js client) Environment
# ===========================================

NODE_ENV=development

# Public app config
NEXT_PUBLIC_APP_URL="http://localhost:3100"
NEXT_PUBLIC_ADMIN_APP_URL="http://localhost:3101"
NEXT_PUBLIC_APP_NAME="Acme"
NEXT_PUBLIC_API_URL="http://localhost:8787"

# Optional E2E credentials for authenticated Playwright runs
E2E_WEB_EMAIL=""
E2E_WEB_PASSWORD=""

# Note
# Backend secrets, database access, email, payments, and Better Auth server config
# now belong to apps/api rather than apps/web.
